# ─────────────────────────────────────────────────────────────────────────────
# MSC NU Laguna API — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ─── Database (MySQL / XAMPP) ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=msc_nulaguna

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate long random strings for production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-another-long-random-string

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at
#   https://myaccount.google.com/apppasswords
# For Microsoft 365: use smtp.office365.com port 587 with your M365 credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM="MSC NU Laguna <your-email@gmail.com>"

# ─── SharePoint Integration (optional) ───────────────────────────────────────
# Required only if using the /api/v1/integrations/sharepoint endpoints.
# Register an app in Azure AD (app registration) to get these values.
# Requires Microsoft Graph API permission: Sites.ReadWrite.All
SP_TENANT_ID=your-azure-tenant-id
SP_CLIENT_ID=your-azure-client-id
SP_CLIENT_SECRET=your-azure-client-secret
# Example site URL:
#   https://yourtenant.sharepoint.com/sites/yoursite
# Maps to:
#   SP_HOSTNAME=yourtenant.sharepoint.com
#   SP_SITE_PATH=/sites/yoursite
SP_HOSTNAME=yourtenant.sharepoint.com
SP_SITE_PATH=/sites/yoursite
SP_SITE_ID=your-sharepoint-site-id
SP_LIST_ID=your-sharepoint-list-id
